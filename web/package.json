    "@vue/tsconfig": "^0.8.1",
    "eslint": "9.39.2",
    "eslint-plugin-playwright": "2.4.1",
    "eslint-plugin-vue": "10.6.2",
    "happy-dom": "20.1.0",
    "jiti": "^2.6.1",
    "npm-run-all2": "^8.0.4",
    "prettier": "3.7.4",
    "resize-observer-polyfill": "^1.5.1",
    "sass-embedded": "1.97.2",
    "typescript": "5.9.3",
    "vite": "7.3.1",
    "vite-plugin-vue-devtools": "8.0.5",
    "vite-plugin-vuetify": "^2.1.2",
    "vitest": "4.0.16",
