    "markdown-it": "^14.1.0",
    "markdown-it-emoji": "^3.0.0",
    "pinia": "3.0.4",
    "svg-pan-zoom": "^3.6.2",
    "vis-timeline": "8.5.0",
    "vue": "3.5.26",
    "vue-i18n": "11.2.8",
    "vue-router": "4.6.4",
    "vuetify": "3.11.6"
  },
  "devDependencies": {
    "@playwright/test": "1.57.0",
    "@tsconfig/node22": "22.0.5",
    "@types/markdown-it": "^14.1.2",
    "@types/markdown-it-emoji": "^3.0.1",
    "@types/node": "25.0.6",
